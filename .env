# ======================================================================
# POSTGRES DATABASE INITIALIZATION (Used by 'db' service)
# ======================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=api_governance_db

# ======================================================================
# BACKEND CONNECTION SETTINGS (Used by 'backend' service)
# ======================================================================
# This tells the backend how to find the database and Ollama inside Docker
DATABASE_URL=postgresql://postgres:admin123@db:5432/api_governance_db
OLLAMA_URL=http://ollama:11434/api/generate

# ======================================================================
# APP CONFIGURATION
# ======================================================================
ENVIRONMENT=development
PROJECT_NAME="BIAT-IT AI Driven OpenAPI Governance and automated publishing"
VERSION=1.0.0

# ======================================================================
# SECURITY
# ======================================================================
# GROQ_API_KEY=your_key_here